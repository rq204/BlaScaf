@inject UserService UserService

<Menu Mode="MenuMode.Inline" Theme="MenuTheme.Light">
    @foreach (var item in FilterMenus(BsConfig.MenuItems))
    {
        <MenuNode Item="item" />
    }
</Menu>

@code {

    [Parameter]
    public bool Collapsed { get; set; }

    protected override void OnParametersSet()
    {
        StateHasChanged(); // ⭐ 强制刷新
    }

    protected override async Task OnInitializedAsync()
    {
        await UserService.LoadUserInfoAsync();
    }

    // ⭐ 递归权限过滤
    private List<BsMenuItem> FilterMenus(List<BsMenuItem> menus)
    {
        return menus
            .Where(m => m.Roles.Contains(UserService.Role))
            .Select(m => new BsMenuItem
                {
                    Key = m.Key,
                    Title = m.Title,
                    Icon = m.Icon,
                    RouterLink = m.RouterLink,
                    Roles = m.Roles,
                    Children = m.Children != null
                        ? FilterMenus(m.Children)
                        : new List<BsMenuItem>()
                })
            .ToList();
    }
}